# Application Settings
APP_NAME="Roomly API"
APP_VERSION="1.0.0"
DEBUG=true

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/roomly

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT Secret
SECRET_KEY=your-secret-key-change-this-in-production-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS Origins (comma-separated)
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Google OAuth (optional for MVP)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# SendGrid Email (optional for MVP)
SENDGRID_API_KEY=
FROM_EMAIL=noreply@roomly.com

# AWS S3 (optional for MVP)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET_NAME=roomly-uploads
AWS_REGION=us-east-1

# Frontend URL
FRONTEND_URL=http://localhost:3000
